@page "/playlist/{Id:int}"
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<style>
    article.px-4 {
        padding: 0 !important;
    }

    .playlist-page {
        margin: 0;
        padding: 0;
        width: 100%;
        background: #0a0a0a;
    }

    .playlist-header {
        background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 50%, #1f1f1f 100%);
        min-height: 340px;
        display: flex;
        align-items: flex-end;
        width: 100%;
        position: relative;
        overflow: hidden;
    }

        .playlist-header::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: radial-gradient(circle at 20% 50%, rgba(96, 165, 250, 0.15) 0%, transparent 50%), radial-gradient(circle at 80% 80%, rgba(139, 92, 246, 0.15) 0%, transparent 50%);
        }

    .playlist-cover {
        width: 232px;
        height: 232px;
        border-radius: 0.5rem;
        object-fit: cover;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5);
        background: linear-gradient(135deg, rgba(96, 165, 250, 0.2) 0%, rgba(139, 92, 246, 0.2) 100%);
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .playlist-cover img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 0.5rem;
        }

        .playlist-cover i {
            font-size: 5rem;
            background: linear-gradient(135deg, #60a5fa 0%, #a78bfa 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

    .playlist-content {
        background: linear-gradient(180deg, rgba(45, 45, 45, 0.3) 0%, #0a0a0a 20%);
        min-height: calc(100vh - 340px);
        width: 100%;
    }

    .action-bar {
        padding: 2rem 0;
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    .btn-play {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: linear-gradient(135deg, #60a5fa 0%, #a78bfa 100%);
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
        box-shadow: 0 4px 12px rgba(96, 165, 250, 0.4);
    }

        .btn-play:hover:not(:disabled) {
            transform: scale(1.1);
            box-shadow: 0 6px 16px rgba(96, 165, 250, 0.6);
        }

        .btn-play:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .btn-play i {
            font-size: 1.5rem;
            margin-left: 3px;
        }

    .btn-add-song {
        background: transparent;
        border: 2px solid rgba(255, 255, 255, 0.3);
        color: white;
        padding: 0.75rem 2rem;
        border-radius: 2rem;
        transition: all 0.3s ease;
        font-weight: 600;
    }

        .btn-add-song:hover {
            border-color: white;
            background: rgba(255, 255, 255, 0.1);
        }

    .btn-primary {
        background: linear-gradient(135deg, #60a5fa 0%, #a78bfa 100%);
        border: none;
        transition: all 0.3s ease;
        box-shadow: 0 4px 12px rgba(96, 165, 250, 0.3);
    }

        .btn-primary:hover {
            background: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 100%);
            transform: scale(1.05);
            box-shadow: 0 6px 16px rgba(96, 165, 250, 0.5);
        }

    .songs-table {
        width: 100%;
    }

        .songs-table thead {
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .songs-table th {
            color: rgba(255, 255, 255, 0.6);
            font-weight: 600;
            font-size: 0.75rem;
            text-transform: uppercase;
            padding: 0.75rem 1rem;
            border: none;
        }

        .songs-table td {
            padding: 0.75rem 1rem;
            border: none;
            color: white;
        }

    .song-row {
        transition: background-color 0.2s ease;
    }

        .song-row:hover {
            background: rgba(255, 255, 255, 0.05);
        }

        .song-row .song-number {
            color: rgba(255, 255, 255, 0.6);
            font-size: 0.875rem;
        }

        .song-row:hover .song-number {
            display: none;
        }

        .song-row .play-icon {
            display: none;
            color: white;
        }

        .song-row:hover .play-icon {
            display: inline;
        }

    .song-info {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .song-thumbnail {
        width: 40px;
        height: 40px;
        border-radius: 0.25rem;
        object-fit: cover;
        background: rgba(96, 165, 250, 0.2);
    }

    .song-title {
        font-weight: 600;
        margin-bottom: 0.25rem;
    }

    .song-artist {
        font-size: 0.875rem;
        color: rgba(255, 255, 255, 0.6);
    }

    .song-duration {
        color: rgba(255, 255, 255, 0.6);
    }

    .btn-remove {
        background: transparent;
        border: none;
        color: rgba(255, 255, 255, 0.6);
        padding: 0.5rem;
        transition: color 0.2s ease;
    }

        .btn-remove:hover {
            color: #ef4444;
        }

    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
    }

        .empty-state i {
            font-size: 5rem;
            background: linear-gradient(135deg, #60a5fa 0%, #a78bfa 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 1.5rem;
        }

        .empty-state h3 {
            color: white;
            font-size: 1.5rem;
            margin-bottom: 0.75rem;
        }

        .empty-state p {
            color: rgba(255, 255, 255, 0.6);
        }

    .text-white-50 {
        color: rgba(255, 255, 255, 0.7);
    }

    .header-content {
        position: relative;
        z-index: 1;
    }

    .back-button {
        color: rgba(255, 255, 255, 0.7);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: color 0.2s ease;
        margin-bottom: 1rem;
    }

        .back-button:hover {
            color: white;
        }

    /* Modal de adicionar música */
    .modal-dark {
        background-color: rgba(10, 10, 10, 0.95);
    }

        .modal-dark .modal-content {
            background: rgba(30, 30, 30, 0.95);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: white;
        }

        .modal-dark .modal-header {
            border-bottom-color: rgba(255, 255, 255, 0.1);
        }

        .modal-dark .btn-close {
            filter: invert(1);
        }

    .search-box {
        background-color: rgba(45, 45, 45, 0.8);
        border-color: rgba(255, 255, 255, 0.1);
        color: white;
    }

        .search-box:focus {
            background-color: rgba(45, 45, 45, 0.9);
            border-color: rgba(96, 165, 250, 0.5);
            color: white;
            box-shadow: 0 0 0 0.25rem rgba(96, 165, 250, 0.15);
        }

        .search-box::placeholder {
            color: rgba(255, 255, 255, 0.4);
        }

    .search-result {
        padding: 0.75rem;
        border-radius: 0.5rem;
        cursor: pointer;
        transition: background-color 0.2s ease;
        margin-bottom: 0.5rem;
    }

        .search-result:hover {
            background: rgba(255, 255, 255, 0.05);
        }

    .btn-add-to-playlist {
        background: linear-gradient(135deg, #60a5fa 0%, #a78bfa 100%);
        border: none;
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 1.5rem;
        font-size: 0.875rem;
        transition: all 0.3s ease;
    }

        .btn-add-to-playlist:hover {
            background: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 100%);
            transform: scale(1.05);
        }
</style>

<PageTitle>@playlist.Nome - Fiapfy</PageTitle>

<div class="playlist-page">
    <!-- Header -->
    <div class="playlist-header">
        <div class="container-fluid px-5 py-5 header-content">
            <a href="/biblioteca" class="back-button">
                <i class="bi bi-arrow-left"></i>
                <span>Voltar para Biblioteca</span>
            </a>
            <div class="row align-items-end">
                <div class="col-auto">
                    <div class="playlist-cover">
                        @if (!string.IsNullOrEmpty(playlist.ImageUrl))
                        {
                            <img src="@playlist.ImageUrl" alt="@playlist.Nome" />
                        }
                        else
                        {
                            <i class="bi bi-music-note-list"></i>
                        }
                    </div>
                </div>
                <div class="col">
                    <p class="text-white-50 mb-2 small text-uppercase fw-semibold">Playlist</p>
                    <h1 class="display-3 fw-bold text-white mb-3">@playlist.Nome</h1>
                    @if (!string.IsNullOrEmpty(playlist.Descricao))
                    {
                        <p class="text-white-50 mb-2">@playlist.Descricao</p>
                    }
                    <p class="text-white-50 mb-0">
                        <span class="fw-semibold">@playlist.CriadoPor</span> •
                        <span>@musicas.Count @(musicas.Count == 1 ? "música" : "músicas")</span>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Conteúdo -->
    <div class="playlist-content">
        <div class="container-fluid px-5">
            <!-- Barra de Ações -->
            <div class="action-bar">
                <button class="btn-play" disabled="@(!musicas.Any())">
                    <i class="bi bi-play-fill text-white"></i>
                </button>
                @if (ehDonoPlaylist)
                {
                    <button class="btn btn-add-song" @onclick="AbrirModalAdicionarMusica">
                        <i class="bi bi-plus-lg me-2"></i>
                        Adicionar músicas
                    </button>
                }
            </div>

            <!-- Lista de Músicas -->
            @if (musicas.Any())
            {
                <table class="songs-table">
                    <thead>
                        <tr>
                            <th style="width: 50px;">#</th>
                            <th>Título</th>
                            <th>Álbum</th>
                            <th style="width: 100px;"><i class="bi bi-clock"></i></th>
                            @if (ehDonoPlaylist)
                            {
                                <th style="width: 50px;"></th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var (musica, index) in musicas.Select((m, i) => (m, i + 1)))
                        {
                            <tr class="song-row">
                                <td>
                                    <span class="song-number">@index</span>
                                    <i class="bi bi-play-fill play-icon"></i>
                                </td>
                                <td>
                                    <div class="song-info">
                                        <img src="@musica.ThumbnailUrl" alt="@musica.Titulo" class="song-thumbnail" />
                                        <div>
                                            <div class="song-title">@musica.Titulo</div>
                                            <div class="song-artist">@musica.Artista</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="song-artist">@musica.Album</td>
                                <td class="song-duration">@musica.Duracao</td>
                                @if (ehDonoPlaylist)
                                {
                                    <td>
                                        <button class="btn-remove" @onclick="() => RemoverMusica(musica.Id)">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-music-note-beamed d-block"></i>
                    <h3>Nenhuma música adicionada</h3>
                    @if (ehDonoPlaylist)
                    {
                        <p class="mb-4">Comece adicionando músicas à sua playlist</p>
                        <button class="btn btn-primary btn-lg rounded-pill px-5" @onclick="AbrirModalAdicionarMusica">
                            <i class="bi bi-plus-lg me-2"></i>Adicionar músicas
                        </button>
                    }
                    else
                    {
                        <p class="mb-4">Esta playlist ainda não possui músicas</p>
                    }
                </div>
            }
        </div>
    </div>
</div>

<!-- Modal Adicionar Música -->
@if (mostrarModal && ehDonoPlaylist)
{
    <div class="modal fade show d-block modal-dark" tabindex="-1" style="background-color: rgba(0, 0, 0, 0.8);">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold">Adicionar Músicas à Playlist</h5>
                    <button type="button" class="btn-close" @onclick="FecharModal"></button>
                </div>
                <div class="modal-body">
                    <!-- Busca -->
                    <div class="mb-4">
                        <input type="text"
                               class="form-control form-control-lg search-box"
                               placeholder="Buscar músicas, artistas ou álbuns..."
                               @bind="termoBusca"
                               @bind:event="oninput" />
                    </div>

                    <!-- Resultados da Busca -->
                    <div style="max-height: 400px; overflow-y: auto;">
                        @if (musicasFiltradas.Any())
                        {
                            @foreach (var musica in musicasFiltradas)
                            {
                                <div class="search-result d-flex align-items-center justify-content-between">
                                    <div class="song-info flex-grow-1">
                                        <img src="@musica.ThumbnailUrl" alt="@musica.Titulo" class="song-thumbnail" />
                                        <div>
                                            <div class="song-title">@musica.Titulo</div>
                                            <div class="song-artist">@musica.Artista • @musica.Album</div>
                                        </div>
                                    </div>
                                    <button class="btn btn-add-to-playlist" @onclick="() => AdicionarMusica(musica)">
                                        <i class="bi bi-plus-lg me-1"></i> Adicionar
                                    </button>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center text-white-50 py-5">
                                <i class="bi bi-search fs-1 mb-3 d-block"></i>
                                <p>@(string.IsNullOrWhiteSpace(termoBusca) ? "Digite para buscar músicas" : "Nenhuma música encontrada")</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    private PlaylistModel playlist = new();
    private List<MusicaModel> musicas = new();
    private List<MusicaModel> musicasDisponiveis = new();
    private bool mostrarModal = false;
    private string termoBusca = string.Empty;
    private string? usuarioAtual;
    private bool ehDonoPlaylist = false;

    private IEnumerable<MusicaModel> musicasFiltradas =>
        string.IsNullOrWhiteSpace(termoBusca)
            ? musicasDisponiveis
            : musicasDisponiveis.Where(m =>
                m.Titulo.Contains(termoBusca, StringComparison.OrdinalIgnoreCase) ||
                m.Artista.Contains(termoBusca, StringComparison.OrdinalIgnoreCase) ||
                m.Album.Contains(termoBusca, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        await ObterUsuarioAtual();
        CarregarPlaylist();
        CarregarMusicas();

        // Verifica se o usuário atual é o dono da playlist
        VerificarPermissoes();

        if (ehDonoPlaylist)
        {
            CarregarMusicasDisponiveis();
        }
    }

    private async Task ObterUsuarioAtual()
    {
        if (AuthenticationStateTask != null)
        {
            var authState = await AuthenticationStateTask;
            var user = authState.User;

            if (user?.Identity?.IsAuthenticated == true)
            {
                usuarioAtual = user.Identity.Name;
            }
        }
    }

    private void VerificarPermissoes()
    {
        // TODO: Comparar com o ID do usuário do backend
        // Por enquanto, compara pelo nome de exibição
        ehDonoPlaylist = !string.IsNullOrEmpty(usuarioAtual) &&
                         playlist.CriadoPor == "Você"; // TODO: Substituir por comparação real com userId
    }

    private void CarregarPlaylist()
    {
        // TODO: Carregar do backend
        playlist = new PlaylistModel
        {
            Id = Id,
            Nome = "Minha Playlist",
            Descricao = "As melhores músicas selecionadas",
            CriadoPor = "Neymar Santos", // TODO: Carregar o nome real do criador
            ImageUrl = "https://picsum.photos/300/300?random=1"
        };
    }

    private void CarregarMusicas()
    {
        // TODO: Carregar do backend
        musicas = new List<MusicaModel>
        {
            new() { Id = 1, Titulo = "Bohemian Rhapsody", Artista = "Queen", Album = "A Night at the Opera", Duracao = "5:55", ThumbnailUrl = "https://picsum.photos/40/40?random=1" },
            new() { Id = 2, Titulo = "Stairway to Heaven", Artista = "Led Zeppelin", Album = "Led Zeppelin IV", Duracao = "8:02", ThumbnailUrl = "https://picsum.photos/40/40?random=2" },
            new() { Id = 3, Titulo = "Hotel California", Artista = "Eagles", Album = "Hotel California", Duracao = "6:30", ThumbnailUrl = "https://picsum.photos/40/40?random=3" },
        };
    }

    private void CarregarMusicasDisponiveis()
    {
        // TODO: Carregar do backend
        musicasDisponiveis = new List<MusicaModel>
        {
            new() { Id = 4, Titulo = "Sweet Child O' Mine", Artista = "Guns N' Roses", Album = "Appetite for Destruction", Duracao = "5:56", ThumbnailUrl = "https://picsum.photos/40/40?random=4" },
            new() { Id = 5, Titulo = "Smells Like Teen Spirit", Artista = "Nirvana", Album = "Nevermind", Duracao = "5:01", ThumbnailUrl = "https://picsum.photos/40/40?random=5" },
            new() { Id = 6, Titulo = "Back in Black", Artista = "AC/DC", Album = "Back in Black", Duracao = "4:15", ThumbnailUrl = "https://picsum.photos/40/40?random=6" },
            new() { Id = 7, Titulo = "Imagine", Artista = "John Lennon", Album = "Imagine", Duracao = "3:03", ThumbnailUrl = "https://picsum.photos/40/40?random=7" },
            new() { Id = 8, Titulo = "Billie Jean", Artista = "Michael Jackson", Album = "Thriller", Duracao = "4:54", ThumbnailUrl = "https://picsum.photos/40/40?random=8" },
        };
    }

    private void AbrirModalAdicionarMusica()
    {
        if (!ehDonoPlaylist)
        {
            return;
        }

        termoBusca = string.Empty;
        mostrarModal = true;
    }

    private void FecharModal()
    {
        mostrarModal = false;
        termoBusca = string.Empty;
    }

    private void AdicionarMusica(MusicaModel musica)
    {
        if (!ehDonoPlaylist)
        {
            return;
        }

        if (!musicas.Any(m => m.Id == musica.Id))
        {
            musicas.Add(musica);
            musicasDisponiveis.Remove(musica);
            // TODO: Salvar no backend
        }
    }

    private void RemoverMusica(int musicaId)
    {
        if (!ehDonoPlaylist)
        {
            return;
        }

        var musica = musicas.FirstOrDefault(m => m.Id == musicaId);
        if (musica != null)
        {
            musicas.Remove(musica);
            musicasDisponiveis.Add(musica);
            // TODO: Remover do backend
        }
    }

    private class PlaylistModel
    {
        public int Id { get; set; }
        public string Nome { get; set; } = string.Empty;
        public string Descricao { get; set; } = string.Empty;
        public string CriadoPor { get; set; } = string.Empty;
        public string ImageUrl { get; set; } = string.Empty;
    }

    private class MusicaModel
    {
        public int Id { get; set; }
        public string Titulo { get; set; } = string.Empty;
        public string Artista { get; set; } = string.Empty;
        public string Album { get; set; } = string.Empty;
        public string Duracao { get; set; } = string.Empty;
        public string ThumbnailUrl { get; set; } = string.Empty;
    }
}