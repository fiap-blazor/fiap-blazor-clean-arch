@page "/playlist/{Id:int}"

@attribute [Authorize]

@inject IPlaylistsAppServico PlaylistsAppServico
@inject IMusicasAppServico MusicasAppServico
@inject IUsuarioAutenticadoServico UsuarioAutenticadoServico
@inject UserManager<ApplicationUser> UserManager

@rendermode InteractiveServer

<PageTitle>Playlist | Fiapfy</PageTitle>

@if (playlist != null)
{
    <div class="playlist-page">
        <!-- Header -->
        <div class="playlist-header">
            <div class="container-fluid px-5 py-5 header-content">
                <a href="/biblioteca" class="back-button">
                    <i class="bi bi-arrow-left"></i>
                    <span>Voltar para Biblioteca</span>
                </a>
                <div class="row align-items-end">
                    <div class="col-auto">
                        <div class="playlist-cover">
                            <i class="bi bi-music-note-list"></i>
                        </div>
                    </div>
                    <div class="col">
                        <p class="text-white-50 mb-2 small text-uppercase fw-semibold">Playlist</p>
                        <h1 class="display-3 fw-bold text-white mb-3">@playlist.Nome</h1>
                        @if (!string.IsNullOrEmpty(playlist.Descricao))
                        {
                            <p class="text-white-50 mb-2">@playlist.Descricao</p>
                        }
                        <p class="text-white-50 mb-0">
                            <span class="fw-semibold">@playlistCriadoPor</span> •
                            <span>@PlaylistCountText</span>
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Conteúdo -->
        <div class="playlist-content">
            <div class="container-fluid px-5">
                <!-- Barra de Ações -->
                <div class="action-bar">
                    <button class="btn-play" disabled="@(!playlist.PlaylistMusicas.Any())">
                        <i class="bi bi-play-fill text-white"></i>
                    </button>
                    @if (ehDonoPlaylist)
                    {
                        <button class="btn btn-add-song" @onclick="AbrirModalAdicionarMusica">
                            <i class="bi bi-plus-lg me-2"></i>
                            Adicionar músicas
                        </button>
                    }
                </div>

                <!-- Lista de Músicas -->
                @if (playlist.PlaylistMusicas.Any())
                {
                    <table class="songs-table">
                        <thead>
                            <tr>
                                <th style="width: 50px;">#</th>
                                <th>Título</th>
                                <th>Álbum</th>
                                <th>Adicionada em</th>
                                <th style="width: 100px;"><i class="bi bi-clock"></i></th>
                                @if (ehDonoPlaylist)
                                {
                                    <th style="width: 50px;"></th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var (musica, index) in playlist.PlaylistMusicas.Select((m, i) => (m, i + 1)))
                            {
                                <tr class="song-row">
                                    <td>
                                        <span class="song-number">@index</span>
                                        <i class="bi bi-play-fill play-icon"></i>
                                    </td>
                                    <td>
                                        <div class="song-info">
                                            <img src="@musica.Musica.AlbumCapaUrl" class="song-thumbnail" />
                                            <div>
                                                <div class="song-title">@musica.Musica.Nome</div>
                                                <div class="song-artist">@musica.Musica.ArtistaNome</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="song-artist">@musica.Musica.AlbumNome</td>
                                    <td class="song-date">@musica.DataAdicaoHumanizada</td>
                                    <td class="song-duration">@musica.Musica.Duracao</td>
                                    @if (ehDonoPlaylist)
                                    {
                                        <td>
                                            <button class="btn-remove" @onclick="() => RemoverMusica(musica.Musica.Id)">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="empty-state">
                        <i class="bi bi-music-note-beamed d-block"></i>
                        <h3>Nenhuma música adicionada</h3>
                        @if (ehDonoPlaylist)
                        {
                            <p class="mb-4">Comece adicionando músicas à sua playlist</p>
                        }
                        else
                        {
                            <p class="mb-4">Esta playlist ainda não possui músicas</p>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Modal Adicionar Música -->
    @if (mostrarModal && ehDonoPlaylist)
    {
        <div class="modal fade show d-block modal-dark" tabindex="-1" style="background-color: rgba(0, 0, 0, 0.8);">
            <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title fw-bold">Adicionar Músicas à Playlist</h5>
                        <button type="button" class="btn-close" @onclick="FecharModal"></button>
                    </div>
                    <div class="modal-body">
                        <!-- Busca -->
                        <div class="mb-4">
                            <input type="text"
                                   class="form-control form-control-lg search-box"
                                   placeholder="Buscar músicas, artistas ou álbuns..."
                                   @bind="termoBusca"
                                   @bind:event="oninput"
                                   @bind:after="RealizarBusca" />
                        </div>

                        <!-- Resultados da Busca -->
                        <div style="max-height: 400px; overflow-y: auto;">
                            @if (buscaRealizada)
                            {
                                @if (resultadosBusca.Registros.Any())
                                {
                                    @foreach (var musica in resultadosBusca.Registros)
                                    {
                                        <div class="search-result d-flex align-items-center justify-content-between">
                                            <div class="song-info flex-grow-1">
                                                <img src="@musica.AlbumCapaUrl" class="song-thumbnail" />
                                                <div>
                                                    <div class="song-title">@musica.Nome</div>
                                                    <div class="song-artist">@musica.ArtistaNome • @musica.AlbumNome</div>
                                                </div>
                                            </div>
                                            <button class="btn btn-add-to-playlist" @onclick="() => AdicionarMusica(musica)">
                                                <i class="bi bi-plus-lg me-1"></i> Adicionar
                                            </button>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="text-center text-white-50 py-5">
                                        <i class="bi bi-search fs-1 mb-3 d-block"></i>
                                        <p>Nenhuma música encontrada</p>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="text-center text-white-50 py-5">
                                    <i class="bi bi-search fs-1 mb-3 d-block"></i>
                                    <p>Digite para buscar músicas</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
}
else
{
    <div class="text-center text-white py-5">
        <p>Carregando playlist...</p>
    </div>
}

